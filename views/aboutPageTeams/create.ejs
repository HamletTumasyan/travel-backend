<div class="action">
    <h1>
        <%= title %>
    </h1>

    <form action="/admin/about-page-teams/add" method="post" enctype="multipart/form-data">

        <label for="lang">Language <span>*</span></label>

        <select name="lang" class="lang-selector" required>
            <option value="" disabled selected>Choose Language</option>

            <% langs.forEach((elem)=> { %>
                <option value="<%= elem.code %>">
                    <%= elem.code %>
                </option>
                <% }); %>

        </select>
        <label for="name">Name <span>*</span></label>
        <input type="text" id="name" name="name" required>

        <label for="profession">Profession <span>*</span></label>
        <input type="text" id="profession" name="profession" required>

        <label for="image">Image <span>*</span></label>
        <input type="file" accept="image/*" id="image" name="image" required>

        <img id="preview" src="" alt="Image preview" class="image-preview">

        <button type="submit" class="submit">Create</button>

    </form>
</div>