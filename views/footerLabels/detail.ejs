<div class="action">
    <h1>
        <%= title %>
    </h1>

    <form action="/admin/<%= activeRoute %>/edit/<%= data.id %>" method="post">
        <label for="lang">Language <span>*</span></label>
        <select id="lang" name="lang" class="lang-selector" required>
            <option value="" disabled selected>Choose Language</option>
            <% langs.forEach((elem)=> { %>
                <option value="<%= elem.code %>" <%=data.lang===elem.code ? 'selected' : '' %>><%= elem.code %>
                </option>
                <% }); %>
        </select>

        <label for="title">Title <span>*</span></label>
        <input type="text" id="title" name="title" value="<%= data.title %>" required>

        <label for="credit">Credit <span>*</span></label>
        <input type="text" id="credit" name="credit" value="<%= data.credit %>" required>

        <button type="submit" class="submit">Update</button>

    </form>
</div>

<hr style="margin: 40px 0;">

<div class="social-links-section">
    <h2>Social Links for this Footer</h2>

    <% if (data.socialLinks && data.socialLinks.length> 0) { %>
        <div class="table-wrapper">
            <table>
                <tr>
                    <th>N</th>
                    <th>Image</th>
                    <th>URL</th>
                    <th>Action</th>
                </tr>
                <% data.socialLinks.forEach((link, idx)=> { %>
                    <tr>
                        <td>
                            <%= idx + 1 %>
                        </td>
                        <td>
                            <a href="<%= link.image %>" target="_blank">
                                <img src="<%= link.image %>" alt="Social Icon" class="social-icon-preview">
                            </a>
                        </td>
                        <td><a href="<%= link.url %>" target="_blank">
                                <%= link.url %>
                            </a></td>
                        <td class="social-link-actions">
                            <a href="/admin/<%= activeRoute %>/<%= data.id %>/social-link/<%= link.id %>" class="btn-edit-social">Edit</a>
                            <form action="/admin/<%= activeRoute %>/<%= data.id %>/social-link/<%= link.id %>/delete"
                                method="POST">
                                <button type="submit" class="btn-delete-social">Delete</button>
                            </form>
                        </td>
                    </tr>
                    <% }); %>
            </table>
        </div>
        <% } else { %>
            <p class="no-data-text">No social links added yet.</p>
            <% } %>

                <div class="add-social-link-form">
                    <h3>Add New Social Link</h3>
                    <form action="/admin/<%= activeRoute %>/<%= data.id %>/social-link/add" method="post"
                        enctype="multipart/form-data">
                        <label for="url">URL (e.g., https://facebook.com/)</label>
                        <input type="text" id="url" name="url" placeholder="https://...">

                        <label for="image">Social Icon Image</label>
                        <input type="file" accept="image/*" id="image" name="image" class="social-image-input">
                        <img id="preview" src="" alt="Preview" class="image-preview">

                        <button type="submit" class="btn-add-social">Add Social Link</button>
                    </form>
                </div>

</div>