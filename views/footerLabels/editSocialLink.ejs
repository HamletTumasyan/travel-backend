<div class="action">
    <h1>
        <%= title %>
    </h1>

    <form action="/admin/<%= activeRoute %>/<%= footerLabelId %>/social-link/<%= data.id %>/edit" method="post"
        enctype="multipart/form-data">

        <label for="url">URL (e.g., https://facebook.com/) <span>*</span></label>
        <input type="text" id="url" name="url" value="<%= data.url %>" required>

        <label for="image">Social Icon Image</label>
        <input type="hidden" name="oldImage" value="<%= data.image %>">

        <div class="image-box">
            <img id="preview" src="<%= data.image %>" class="image-preview active" alt="Current image"
                style="max-height: 100px;">
            <input type="file" accept="image/*" id="image" name="image" class="social-image-input">
        </div>

        <button type="submit" class="submit">Update Social Link</button>
        <a href="/admin/<%= activeRoute %>/<%= footerLabelId %>" class="back-link">&larr; Back to Footer Label</a>

    </form>
</div>