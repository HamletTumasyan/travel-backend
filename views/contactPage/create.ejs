<div class="action">
  <h1> <%= title %> </h1>

    <form action="/admin/<%= activeRoute %>/add" method="post">
        <label for="lang">Language <span>*</span></label>
        <select id="lang" name="lang" class="lang-selector" required>
            <option value="" disabled selected>Choose Language</option>
            <% langs.forEach(lang => { %>
                <option value="<%= lang.code %>"><%= lang.code %></option>
            <% }) %>
        </select>

        <label for="title">Title <span>*</span></label>
        <input type="text" id="title" name="title" required>

        <label for="form_input_name_placeholder">Name Placeholder <span>*</span></label>
        <input type="text" id="form_input_name_placeholder" name="form_input_name_placeholder" required>

        <label for="form_input_email_placeholder">Email Placeholder <span>*</span></label>
        <input type="text" id="form_input_email_placeholder" name="form_input_email_placeholder" required>

        <label for="form_input_message_placeholder">Message Placeholder <span>*</span></label>
        <input type="text" id="form_input_message_placeholder" name="form_input_message_placeholder" required>

        <label for="btn_text">Button Text <span>*</span></label>
        <input type="text" id="btn_text" name="btn_text" required>

        <label for="form_send_successfully">Success Message <span>*</span></label>
        <textarea id="form_send_successfully" name="form_send_successfully" required></textarea>

        <label for="form_send_error">Error Message <span>*</span></label>
        <textarea id="form_send_error" name="form_send_error" required></textarea>

        <button type="submit" class="submit">Create</button>

    </form>
</div>