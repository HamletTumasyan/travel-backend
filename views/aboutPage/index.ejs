<div class="head">
    <h1>
        <%= title %>
    </h1>
</div>

<div class="section">
    <h2>Intros</h2>
    <div class="right-side">
        <form action="/admin/about-page-intros/bulk-delete" id="bulk-delete-intros-form" method="post">
            <input type="hidden" name="ids" id="selected-intros-ids">
            <button type="submit" id="delete-intros-btn" class="delete-btn" style="display: none;">
                Delete 0 selected intros
            </button>
        </form>
        <a href="/admin/about-page-intros/create" class="create-btn">Add Intro</a>
    </div>
</div>

<% if (introsData && introsData.length) { %>
    <div class="table-wrapper">
        <table>
            <tr>
                <td><input type="checkbox" id="select-all-intros"></td>
                <th>N</th>
                <th>Lang</th>
                <th>Title</th>
                <th>Description</th>
                <th>Details</th>
            </tr>
            <% introsData.forEach((elem, index)=> { %>
                <tr>
                    <td>
                        <input type="checkbox" class="row-checkbox-intros" value="<%= elem.id %>">
                    </td>
                    <td>
                        <%= index + 1 %>
                    </td>
                    <td>
                        <%= elem.lang %>
                    </td>
                    <td>
                        <%= elem.title %>
                    </td>
                    <td>
                        <%= elem.descr.slice(0, 50) + '...' %>
                    </td>
                    <td>
                        <a href="/admin/about-page-intros/<%= elem.id %>" class="action">View</a>
                    </td>
                </tr>
            <% }) %>
        </table>
    </div>
<% } else { %>
    <p class="no-data-text">No intros yet.</p>
<% } %>

